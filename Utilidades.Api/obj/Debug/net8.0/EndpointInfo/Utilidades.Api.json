      "CodigoPostalDto": {
        "type": "object",
        "properties": {
          "codigoPostal": {
            "type": "string",
            "nullable": true
          },
          "alcaldiaId": {
            "type": "integer",
            "format": "int32"
          },
          "estado": {
            "type": "string",
            "nullable": true
          },
          "estadoId": {
            "type": "integer",
            "format": "int32"
          },
          "alcaldia": {
            "type": "string",
            "nullable": true
          },
          "tipoDeAsentamiento": {
            "type": "string",
            "nullable": true
          },
          "asentamiento": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ContadorDto": {
        "type": "object",
        "properties": {
          "key": {
            "maxLength": 64,
            "type": "string",
            "nullable": true
          },
          "valorMin": {
            "maximum": 2147483647,
            "minimum": 0,
            "type": "integer",
            "format": "int32"
          },
          "valorMax": {
            "maximum": 2147483647,
            "minimum": 0,
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "CurpDto": {
        "type": "object",
        "properties": {
          "curp": {
            "type": "string",
            "nullable": true
          },
          "fecha": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      },
      "Estado": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "nullable": true
          },
          "nombre": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "RfcDto": {
        "required": [
          "fechaDeNacimiento",
          "nombre",
          "primerApellido",
          "segundoApellido",
          "tipoDePersona"
        ],
        "type": "object",
        "properties": {
          "tipoDePersona": {
            "$ref": "#/components/schemas/TipoPersona"
          },
          "nombre": {
            "minLength": 1,
            "type": "string"
          },
          "primerApellido": {
            "minLength": 1,
            "type": "string"
          },
          "segundoApellido": {
            "minLength": 1,
            "type": "string"
          },
          "fechaDeNacimiento": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      },
      "SolicitudDeCurp": {
        "required": [
          "estado",
          "fechaDeNacimiento",
          "nombres",
          "primerApellido",
          "sexo"
        ],
        "type": "object",
        "properties": {
          "nombres": {
            "maxLength": 50,
            "minLength": 1,
            "type": "string",
            "description": "Gets or sets the first names of the person."
          },
          "primerApellido": {
            "maxLength": 50,
            "minLength": 1,
            "type": "string",
            "description": "Gets or sets the first surname of the person."
          },
          "segundoApellido": {
            "maxLength": 50,
            "type": "string",
            "description": "Gets or sets the second surname of the person.",
            "nullable": true
          },
          "fechaDeNacimiento": {
            "type": "string",
            "description": "Gets or sets the date of birth.",
            "format": "date-time"
          },
          "sexo": {
            "maxLength": 1,
            "minLength": 1,
            "pattern": "^[HhMm]$",
            "type": "string",
            "description": "H, M"
          },
          "estado": {
            "minLength": 1,
            "type": "string",
            "description": "Aguascalientes, Baja_California, Baja_California_Sur, Campeche, Coahuila, Colima, Chiapas, Chihuahua, Distrito_Federal, Durango, Guanajuato, Guerrero, Hidalgo, Jalisco, Mexico, Michoacan, Morelos, Nayarit, Nuevo_Leon, Oaxaca, Puebla, Queretaro, Quintana_Roo, San_Luis_Potosi, Sinaloa, Sonora, Tabasco, Tamaulipas, Tlaxcala, Veracruz, Yucatan, Zacatecas, Extranjero"
          }
        },
        "additionalProperties": false
      },
      "TipoPersona": {
        "enum": [
          0,
          1
        ],
        "type": "integer",
        "format": "int32"
      },
      "WebHook": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string",
            "nullable": true
          },
          "body": {
            "type": "string",
            "nullable": true
          },
          "fechaDeRegistro": {
            "type": "string",
            "format": "date-time"
          },
          "encodedkey": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    },
    "securitySchemes": {
      "bearer": {
        "type": "http",
        "description": "Introduce sólo el token. El prefijo 'Bearer' se agrega automáticamente.",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      },
      "basic": {
        "type": "http",
        "description": "Use Basic authentication: Authorization: Basic {base64(correo:contraseña)}",
        "scheme": "basic"
      }
    }
  }
